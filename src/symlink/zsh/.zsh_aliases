alias showdesktop="defaults write com.apple.finder CreateDesktop -bool true && killall Finder"
alias hidedesktop="defaults write com.apple.finder CreateDesktop -bool false && killall Finder"

alias showsystem="defaults write com.apple.finder AppleShowAllFiles -bool true && killall Finder"
alias hidesystem="defaults write com.apple.finder AppleShowAllFiles -bool false && killall Finder"

alias -- -="cd -"             # (-) returns to the last visited directory
alias ~="cd ~"                # (~) navigates to the user home directory
alias cd..="cd .."            # cd..
alias ..="cd .."              # ..
alias ...="cd ../.."          # ...
alias ....="cd ../../.."      # ....
alias .....="cd ../../../.."  # .....

alias ip="ipconfig getifaddr en0"

alias dir="pwd"               # shows the absolute path of the current directory

alias ls="command ls -G"      # displays files and directories using colors to differentiate them
alias ll="command ls -lFG"    # displays a detailed listing with permissions, size, and other details
alias la="command ls -laFG"   # displays a detailed listing, including hidden files

alias h=history
alias clr=clear
alias clrh="history -c; history -w"

alias topdir="du -h -d 1 ~ 2>/dev/null | sort -hr | head"

# cleaning
alias clean-cache="rm -rf ~/Library/Caches/*"
alias clean-logs="rm -rf ~/Library/Logs/*"
alias clean-pip="python3 -m pip cache purge"
alias clean-npm="npm cache clean --force"
alias clean-brew="brew cleanup -s"
alias clean-docker="docker system prune -f"
alias clean-dsstore="find . -type f -name '*.DS_Store' -ls -delete"

# list
alias list-venvs="find ~ -maxdepth 4 -type d \( -name ".venv" -o -name "venv" \) -print 2>/dev/null"
alias list-node-modules="find ~ -type d -name "node_modules" -prune -print 2>/dev/null | head"

doctor() {
  eval "brew doctor"
  echo
  echo
  eval "npm cache verify"
}

devspace() {
  echo "===== XCODE / IOS ====="
  du -sh ~/Library/Developer/* 2>/dev/null
  du -sh ~/Library/Developer/Xcode/* 2>/dev/null

  echo "\n===== ANDROID ====="
  du -sh ~/Library/Android/* 2>/dev/null
  du -sh ~/Library/Android/sdk/* 2>/dev/null

  echo "\n===== DOCKER ====="
  docker system df 2>/dev/null

  echo "\n===== HOMEBREW ====="
  du -sh /opt/homebrew 2>/dev/null
  du -sh /opt/homebrew/Cellar 2>/dev/null
  du -sh /opt/homebrew/Caskroom 2>/dev/null
  du -sh ~/Library/Caches/Homebrew 2>/dev/null

  echo "\n===== NODE / JAVASCRIPT ====="
  du -sh ~/.npm 2>/dev/null
  du -sh ~/.nvm 2>/dev/null
  du -sh ~/.yarn 2>/dev/null
  du -sh ~/Library/pnpm 2>/dev/null
  du -sh ~/Library/Caches/Yarn 2>/dev/null

  echo "\n===== PYTHON ====="
  du -sh ~/.pyenv 2>/dev/null
  du -sh ~/Library/Caches/pip 2>/dev/null

  echo "\n===== GRADLE ====="
  du -sh ~/.gradle 2>/dev/null

  echo "\n===== AI / MODELS ====="
  du -sh ~/.ollama 2>/dev/null
  du -sh ~/.cache/huggingface 2>/dev/null
  du -sh ~/.codex 2>/dev/null
  du -sh ~/.claude 2>/dev/null

  echo "\n===== APPLICATION DATA ====="
  du -sh ~/Library/Application\ Support/Code 2>/dev/null
  du -sh ~/Library/Application\ Support/AndroidStudio* 2>/dev/null
  du -sh ~/Library/Application\ Support/Google/Chrome 2>/dev/null

  echo "\n===== CACHE ====="
  du -sh ~/Library/Caches/Google 2>/dev/null
  du -sh ~/Library/Caches/Homebrew 2>/dev/null

  echo "\n===== TOP 20 DIRECTORIES ====="
  du -hd 1 ~ 2>/dev/null | sort -hr | head -20

  echo "\n===== TOP 15 LARGEST FILES ====="
  find ~ \
    -type f \
    -not -path "*/Library/*" \
    -exec stat -f "%z %N" {} + 2>/dev/null \
    | sort -nr \
    | head -15 \
    | awk '
      {
        size=$1
        $1=""
        file=substr($0,2)

        split("B KB MB GB TB",u)
        i=1

        while(size>1024 && i<5){
          size/=1024
          i++
        }

        printf "%.2f %s\t%s\n", size,u[i],file
      }'

  echo "\n===== OLLAMA MODELS ====="
  ollama list 2>/dev/null
}

decrypt() {
  local dir="$DECRYPT_FOLDER"

  if [ -z "$dir" ]; then
    echo "Variable DECRYPT_FOLDER not defined"
    return 1
  fi

  if [ ! -d "$dir" ]; then
    echo "Directory not found: $dir"
    return 1
  fi

  local files=()
  local names=()

  for f in "$dir"/*.vault; do
    if [ -f "$f" ]; then
      files+=("$f")
      names+=("$(basename "$f")")
    fi
  done

  if [ ${#files[@]} -eq 0 ]; then
    echo "No files found in: $dir"
    return 1
  fi

  echo "Select a file:"
  PS3="Option: "

  select name in "${names[@]}"; do
    if [ -n "$name" ]; then
      local file="${files[$REPLY]}"

      echo "Selected: $name"

      echo -n "Enter password: "
      read -s password
      echo

      cryptography decrypt "$password" "$file"

      unset password
      break
    else
      echo "Invalid option"
    fi
  done
}
